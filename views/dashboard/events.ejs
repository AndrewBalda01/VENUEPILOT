<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VenuePilot — Events</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar', { page: 'events' }) %>

    <main class="main">
      <header class="topbar">
        <h1 class="topbar-title">Events</h1>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </button>
        </form>
      </header>

      <div class="content">
        <% if (success === 'created') { %>
          <div class="alert alert-success">Event created successfully.</div>
        <% } %>
        <% if (success === 'updated') { %>
          <div class="alert alert-success">Event updated successfully.</div>
        <% } %>
        <% if (success === 'deleted') { %>
          <div class="alert alert-success">Event deleted successfully.</div>
        <% } %>

        <div class="events-toolbar">
          <div class="toolbar-left">
            <form method="GET" class="search-form">
              <input type="text" name="search" placeholder="Search events..." value="<%= search %>" class="input-search">
              <select name="status" class="select-filter" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <% statuses.forEach(s => { %>
                  <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn btn-sm">Filter</button>
              <% if (search || status) { %>
                <a href="/dashboard/events" class="btn btn-sm btn-text">Clear</a>
              <% } %>
            </form>
          </div>
          <button class="btn btn-primary" id="btnAddEvent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Event
          </button>
        </div>

        <div class="card">
          <% if (events.length === 0) { %>
            <div class="empty-state">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <h3>No events found</h3>
              <p>Create your first event to get started.</p>
              <button class="btn btn-primary" id="btnAddEventEmpty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Event
              </button>
            </div>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Location</th>
                    <th>Date</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th class="actions-col">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% events.forEach(event => { %>
                    <tr>
                      <td class="td-title"><%= event.title %></td>
                      <td><%= event.category %></td>
                      <td><%= event.location %></td>
                      <td><%= new Date(event.event_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                      <td><%= event.capacity %></td>
                      <td><span class="badge badge-<%= event.status.toLowerCase().replace(' ', '-') %>"><%= event.status %></span></td>
                      <td class="actions-cell">
                        <button class="btn-icon btn-edit" data-id="<%= event.id %>" title="Edit">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button class="btn-icon btn-delete" data-id="<%= event.id %>" title="Delete">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <div class="modal-overlay" id="eventModal">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modalTitle">Add Event</h2>
        <button class="modal-close" id="modalClose">&times;</button>
      </div>
      <form id="eventForm">
        <input type="hidden" id="eventId">
        <div class="form-row">
          <div class="form-group">
            <label for="eventTitle">Title *</label>
            <input type="text" id="eventTitle" name="title" required>
          </div>
          <div class="form-group">
            <label for="eventCategory">Category *</label>
            <input type="text" id="eventCategory" name="category" required placeholder="Music, Business, Social...">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="eventLocation">Location *</label>
            <input type="text" id="eventLocation" name="location" required placeholder="Main Hall, Rooftop...">
          </div>
          <div class="form-group">
            <label for="eventDate">Date & Time *</label>
            <input type="datetime-local" id="eventDate" name="event_date" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="eventCapacity">Capacity *</label>
            <input type="number" id="eventCapacity" name="capacity" required min="0">
          </div>
          <div class="form-group">
            <label for="eventStatus">Status</label>
            <select id="eventStatus" name="status">
              <option value="Draft">Draft</option>
              <option value="Scheduled">Scheduled</option>
              <option value="Sold Out">Sold Out</option>
              <option value="Completed">Completed</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="eventDescription">Description</label>
          <textarea id="eventDescription" name="description" rows="3"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline" id="modalCancel">Cancel</button>
          <button type="submit" class="btn btn-primary" id="modalSubmit">Create Event</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="deleteModal">
    <div class="modal modal-sm">
      <div class="modal-header">
        <h2>Delete Event</h2>
        <button class="modal-close" id="deleteClose">&times;</button>
      </div>
      <p class="delete-confirm">Are you sure you want to delete this event? This action cannot be undone.</p>
      <div class="modal-actions">
        <button class="btn btn-outline" id="deleteCancel">Cancel</button>
        <button class="btn btn-danger" id="deleteConfirm">Delete</button>
      </div>
    </div>
  </div>

  <script src="/js/dashboard.js"></script>
</body>
</html>
