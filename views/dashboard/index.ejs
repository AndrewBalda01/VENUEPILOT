<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VenuePilot — Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar', { page: 'dashboard' }) %>

    <main class="main">
      <header class="topbar">
        <h1 class="topbar-title">Dashboard</h1>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </button>
        </form>
      </header>

      <div class="content">
        <div class="kpi-grid">
          <div class="kpi-card">
            <div class="kpi-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="kpi-body">
              <span class="kpi-value"><%= stats.total %></span>
              <span class="kpi-label">Total Events</span>
            </div>
          </div>
          <div class="kpi-card kpi-accent">
            <div class="kpi-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="kpi-body">
              <span class="kpi-value"><%= stats.upcoming %></span>
              <span class="kpi-label">Upcoming</span>
            </div>
          </div>
          <div class="kpi-card kpi-gold">
            <div class="kpi-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div class="kpi-body">
              <span class="kpi-value"><%= stats.soldOut %></span>
              <span class="kpi-label">Sold Out</span>
            </div>
          </div>
        </div>

        <div class="dashboard-actions">
          <a href="/dashboard/events" class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Manage Events
          </a>
        </div>

        <div class="card">
          <h2 class="card-title">Recent Events</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Date</th>
                  <th>Location</th>
                  <th>Status</th>
                  <th>Capacity</th>
                </tr>
              </thead>
              <tbody>
                <% if (recentEvents && recentEvents.length > 0) { %>
                  <% recentEvents.forEach(event => { %>
                    <tr>
                      <td class="td-title"><%= event.title %></td>
                      <td><%= new Date(event.event_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                      <td><%= event.location %></td>
                      <td><span class="badge badge-<%= event.status.toLowerCase().replace(' ', '-') %>"><%= event.status %></span></td>
                      <td><%= event.capacity %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" style="text-align:center;color:var(--text-secondary);padding:32px;">No events yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
